@@ -0,0 +1,198 @@
+import Link from 'next/link'
+import { asc, desc } from 'drizzle-orm'
+import { db } from '@/db/client'
+import {
+  changelogEntries,
+  type ChangelogCategory,
+  type ChangelogEntry,
+} from '@/db/schema'
+
+// Reads the DB per request — never prerendered at build time.
+export const dynamic = 'force-dynamic'
+
+export const metadata = {
+  title: 'Changelog · Dinner',
+  description: 'What’s new in Dinner.',
+}
+
+// Display labels for each category. The object is keyed by every enum value so
+// adding a category to the enum is a compile error here until it's labelled.
+const CATEGORY_LABEL: Record<ChangelogCategory, string> = {
+  added: 'Added',
+  changed: 'Changed',
+  fixed: 'Fixed',
+  removed: 'Removed',
+}
+
+type CategoryGroup = { category: ChangelogCategory; entries: ChangelogEntry[] }
+type VersionGroup = {
+  version: string
+  releasedAt: string
+  categories: CategoryGroup[]
+}
+
+// Groups the flat, already-sorted entry list into version → category buckets
+// while preserving the incoming order. The DB query does the actual ordering
+// (newest version first, canonical category order, then sort_order), so this
+// only needs to fold consecutive runs — never re-sort.
+function groupEntries(entries: ChangelogEntry[]): VersionGroup[] {
+  const versions: VersionGroup[] = []
+  for (const entry of entries) {
+    let version = versions[versions.length - 1]
+    if (!version || version.version !== entry.version) {
+      version = {
+        version: entry.version,
+        releasedAt: entry.releasedAt,
+        categories: [],
+      }
+      versions.push(version)
+    }
+    let category = version.categories[version.categories.length - 1]
+    if (!category || category.category !== entry.category) {
+      category = { category: entry.category, entries: [] }
+      version.categories.push(category)
+    }
+    category.entries.push(entry)
+  }
+  return versions
+}
+
+// Formats a 'YYYY-MM-DD' date column without going through Date() (which would
+// shift the day across timezones for a date-only value).
+function formatReleaseDate(iso: string): string {
+  const [year, month, day] = iso.split('-').map(Number)
+  const months = [
+    'January', 'February', 'March', 'April', 'May', 'June',
+    'July', 'August', 'September', 'October', 'November', 'December',
+  ]
+  if (!year || !month || !day) return iso
+  return `${months[month - 1]} ${day}, ${year}`
+}
+
+export default async function ChangelogPage() {
+  const entries = await db
+    .select()
+    .from(changelogEntries)
+    // Canonical ordering: newest version first (by release date, then version),
+    // then category in enum-declaration order, then the manual sort key. An
+    // enum column sorts by its label declaration order in Postgres, so
+    // `asc(category)` yields Added → Changed → Fixed → Removed.
+    .orderBy(
+      desc(changelogEntries.releasedAt),
+      desc(changelogEntries.version),
+      asc(changelogEntries.category),
+      asc(changelogEntries.sortOrder),
+      asc(changelogEntries.createdAt),
+    )
+
+  const versions = groupEntries(entries)
+
+  return (
+    <div
+      style={{
+        minHeight: '100dvh',
+        maxWidth: 448,
+        margin: '0 auto',
+        background: 'var(--bg)',
+        display: 'flex',
+        flexDirection: 'column',
+      }}
+    >
+      {/* Header */}
+      <div
+        style={{
+          height: 56,
+          flexShrink: 0,
+          display: 'flex',
+          alignItems: 'center',
+          justifyContent: 'space-between',
+          padding: '0 20px',
+          borderBottom: '1px solid var(--border)',
+        }}
+      >
+        <div style={{ fontSize: 22, fontWeight: 700, color: 'var(--text)', letterSpacing: -0.5 }}>
+          Changelog
+        </div>
+        <Link
+          href="/calendar"
+          style={{ fontSize: 14, fontWeight: 600, color: 'var(--accent)', textDecoration: 'none' }}
+        >
+          Dinner →
+        </Link>
+      </div>
+
+      {versions.length === 0 ? (
+        <div
+          style={{
+            flex: 1,
+            display: 'flex',
+            flexDirection: 'column',
+            alignItems: 'center',
+            justifyContent: 'center',
+            gap: 8,
+            padding: 24,
+            textAlign: 'center',
+          }}
+        >
+          <div style={{ fontSize: 17, fontWeight: 600, color: 'var(--text)' }}>
+            Nothing here yet
+          </div>
+          <div style={{ fontSize: 14, color: 'var(--text-2)', maxWidth: 260, lineHeight: 1.5 }}>
+            Release notes will show up here as new features ship.
+          </div>
+        </div>
+      ) : (
+        <div style={{ flex: 1, overflowY: 'auto', padding: '24px 22px 44px' }}>
+          {versions.map((version) => (
+            <section key={version.version} style={{ marginBottom: 34 }}>
+              <div style={{ display: 'flex', alignItems: 'baseline', gap: 10, marginBottom: 4 }}>
+                <h2 style={{ fontSize: 20, fontWeight: 700, color: 'var(--text)', letterSpacing: -0.3, margin: 0 }}>
+                  v{version.version}
+                </h2>
+              </div>
+              <div style={{ fontSize: 12.5, fontWeight: 500, color: 'var(--text-2)', marginBottom: 16 }}>
+                {formatReleaseDate(version.releasedAt)}
+              </div>
+
+              {version.categories.map((group) => (
+                <div key={group.category} style={{ marginBottom: 18 }}>
+                  <div
+                    style={{
+                      fontSize: 11,
+                      fontWeight: 700,
+                      letterSpacing: 0.8,
+                      textTransform: 'uppercase',
+                      color: 'var(--accent)',
+                      marginBottom: 9,
+                    }}
+                  >
+                    {CATEGORY_LABEL[group.category]}
+                  </div>
+                  <ul style={{ margin: 0, padding: 0, listStyle: 'none', display: 'flex', flexDirection: 'column', gap: 9 }}>
+                    {group.entries.map((entry) => (
+                      <li key={entry.id} style={{ display: 'flex', gap: 11, alignItems: 'flex-start' }}>
+                        <span
+                          style={{
+                            width: 6,
+                            height: 6,
+                            borderRadius: '50%',
+                            background: 'var(--accent)',
+                            marginTop: 8,
+                            flexShrink: 0,
+                          }}
+                        />
+                        <span style={{ fontSize: 15, lineHeight: 1.5, color: 'var(--text)' }}>
+                          {entry.description}
+                        </span>
+                      </li>
+                    ))}
+                  </ul>
+                </div>
+              ))}
+            </section>
+          ))}
+        </div>
+      )}
+    </div>
+  )
+}
