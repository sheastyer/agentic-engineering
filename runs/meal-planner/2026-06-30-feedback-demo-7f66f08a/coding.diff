+// ── changelog ─────────────────────────────────────────────────────────────
+// Public product changelog. Not tenant-scoped — the same release notes are
+// shown to everyone (and to logged-out visitors on the public /changelog page).
+//
+// Categories follow the "Keep a Changelog" convention. The enum's declaration
+// order IS the canonical display order: Postgres sorts an enum column by the
+// order its labels were defined, so `ORDER BY category` groups entries as
+// Added → Changed → Fixed → Removed with no extra sort key.
+export const changelogCategory = pgEnum('changelog_category', [
+  'added',
+  'changed',
+  'fixed',
+  'removed',
+])
+
+// One row per bullet point. Grouped in the UI by `version` (newest first, via
+// `released_at`) then `category` (canonical enum order) then `sort_order`.
+export const changelogEntries = pgTable('changelog_entries', {
+  id: uuid('id').primaryKey().defaultRandom(),
+  // Semantic version string this entry shipped in, e.g. "1.0.0".
+  version: text('version').notNull(),
+  // Release date of the version — drives newest-first version ordering.
+  releasedAt: date('released_at').notNull(),
+  category: changelogCategory('category').notNull(),
+  description: text('description').notNull(),
+  // Manual ordering of entries within a (version, category) group.
+  sortOrder: integer('sort_order').notNull().default(0),
+  createdAt: timestamp('created_at', { withTimezone: true }).defaultNow(),
+})
+
+export type ChangelogCategory = (typeof changelogCategory.enumValues)[number]
+export type ChangelogEntry = typeof changelogEntries.$inferSelect
+
 export type Household = typeof households.$inferSelect
 export type Session = typeof sessions.$inferSelect
 export type FamilyMember = typeof familyMembers.$inferSelect
