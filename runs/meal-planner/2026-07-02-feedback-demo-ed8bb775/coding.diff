+// ── Clear checked items — confirm dialog ────────────────────────────────
+// A destructive, non-optimistic bulk action, so it gets a confirm step
+// (unlike the single-item delete/check-toggle, which are optimistic and
+// individually reversible). Same backdrop + role="dialog" pattern as
+// FeedbackButton's modal.
+function ClearCheckedDialog({
+  count,
+  clearing,
+  error,
+  onConfirm,
+  onCancel,
+}: {
+  count: number
+  clearing: boolean
+  error: string | null
+  onConfirm: () => void
+  onCancel: () => void
+}) {
+  return (
+    <>
+      <div
+        role="none"
+        onClick={clearing ? undefined : onCancel}
+        style={{ position: 'fixed', inset: 0, zIndex: 60, background: 'rgba(0,0,0,0.4)' }}
+      />
+      <div
+        role="dialog"
+        aria-modal="true"
+        aria-labelledby="clear-checked-title"
+        style={{
+          position: 'fixed',
+          left: '50%',
+          top: '50%',
+          transform: 'translate(-50%, -50%)',
+          zIndex: 61,
+          width: 'calc(100vw - 48px)',
+          maxWidth: 360,
+          background: 'var(--surface)',
+          border: '1px solid var(--border)',
+          borderRadius: 18,
+          padding: 22,
+          boxShadow: 'var(--shadow-lg, 0 8px 24px rgba(0,0,0,0.24))',
+        }}
+      >
+        <div id="clear-checked-title" style={{ fontSize: 17, fontWeight: 700, color: 'var(--text)' }}>
+          Clear checked items?
+        </div>
+        <div style={{ marginTop: 8, fontSize: 14, lineHeight: 1.5, color: 'var(--text-2)' }}>
+          {count === 1
+            ? 'This removes the 1 checked item from your list. This can’t be undone.'
+            : `This removes all ${count} checked items from your list. This can’t be undone.`}
+        </div>
+        {error && (
+          <div role="alert" style={{ marginTop: 12, fontSize: 13, fontWeight: 600, color: 'var(--terracotta)' }}>
+            {error}
+          </div>
+        )}
+        <div style={{ marginTop: 20, display: 'flex', gap: 10 }}>
+          <button
+            onClick={onCancel}
+            disabled={clearing}
+            style={{
+              flex: 1,
+              height: 46,
+              borderRadius: 12,
+              fontSize: 14.5,
