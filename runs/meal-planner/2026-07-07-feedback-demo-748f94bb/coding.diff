+// ── Pantry staples: add control + chip list ─────────────────────────────────
+function PantryStaplesEditor({
+  staples,
+  onAdd,
+  onRemove,
+  disabled,
+}: {
+  staples: string[]
+  onAdd: (value: string) => void
+  onRemove: (staple: string) => void
+  disabled: boolean
+}) {
+  const [draft, setDraft] = useState('')
+
+  const submit = () => {
+    if (!draft.trim()) return
+    onAdd(draft)
+    setDraft('')
+  }
+
+  return (
+    <div style={{ marginTop: 10 }}>
+      <div style={{ display: 'flex', gap: 8 }}>
+        <input
+          value={draft}
+          onChange={(e) => setDraft(e.target.value)}
+          onKeyDown={(e) => {
+            if (e.key === 'Enter') {
+              e.preventDefault()
+              submit()
+            }
+          }}
+          placeholder="e.g. Olive oil, Salt, Rice"
+          disabled={disabled}
+          maxLength={PANTRY_STAPLE_MAX}
+          aria-label="Add a pantry staple"
+          style={{
+            flex: 1,
+            minWidth: 0,
+            border: '1.5px solid var(--border)',
+            borderRadius: 12,
+            background: 'var(--bg)',
+            padding: '11px 13px',
+            fontSize: 16,
+            lineHeight: 1.5,
+            color: 'var(--text)',
+            fontFamily: 'inherit',
+            outline: 'none',
+          }}
+        />
+        <button
+          onClick={submit}
+          disabled={disabled || !draft.trim()}
+          style={{
+            flexShrink: 0,
+            padding: '0 18px',
+            borderRadius: 12,
+            fontSize: 14.5,
+            fontWeight: 600,
+            background: 'var(--accent)',
+            color: 'var(--on-accent)',
+            border: 'none',
+            opacity: disabled || !draft.trim() ? 0.5 : 1,
+          }}
+        >
+          Add
+        </button>
+      </div>
+
+      {staples.length === 0 ? (
+        <div style={{ marginTop: 10, fontSize: 13.5, color: 'var(--text-3)' }}>
+          No staples yet — add the ingredients you always have on hand.
+        </div>
+      ) : (
+        <div style={{ marginTop: 10, display: 'flex', flexWrap: 'wrap', gap: 8 }}>
+          {staples.map((s) => (
+            <span
+              key={s}
+              style={{
+                display: 'flex',
+                alignItems: 'center',
+                gap: 6,
+                borderRadius: 999,
+                padding: '7px 8px 7px 12px',
+                border: '1.5px solid var(--border)',
+                background: 'var(--surface)',
+                fontSize: 13.5,
+                fontWeight: 600,
+                color: 'var(--text)',
+              }}
+            >
+              {s}
+              <button
+                onClick={() => onRemove(s)}
+                disabled={disabled}
+                aria-label={`Remove ${s}`}
+                style={{
+                  width: 18,
+                  height: 18,
+                  flexShrink: 0,
+                  borderRadius: '50%',
+                  display: 'flex',
+                  alignItems: 'center',
+                  justifyContent: 'center',
+                  fontSize: 11,
+                  lineHeight: 1,
+                  color: 'var(--text-3)',
+                  background: 'var(--accent-tint)',
+                  border: 'none',
+                }}
+              >
+                ✕
+              </button>
+            </span>
+          ))}
+        </div>
+      )}
+    </div>
+  )
+}
