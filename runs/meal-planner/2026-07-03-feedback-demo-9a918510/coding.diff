+// Shared catalog for the household's cooking profile: how confident they are in
+// the kitchen (skill level) and what appliances they own (equipment). Both are
+// household-level context threaded into every recommendation prompt — the skill
+// level steers recipe complexity (soft signal) and the equipment list is a hard
+// constraint (never suggest a recipe that needs a tool the household lacks).
+// One module so the schema, API validation, UI controls, and prompt all agree
+// on the same ids and labels.
+
+// ── Cooking skill level ─────────────────────────────────────────────────────
+// A small fixed ladder. Declaration order is the canonical display order
+// (least → most experienced).
+export const COOKING_SKILL_LEVELS = ['beginner', 'intermediate', 'advanced'] as const
+
+export type CookingSkillLevel = (typeof COOKING_SKILL_LEVELS)[number]
+
+export function isCookingSkillLevel(v: unknown): v is CookingSkillLevel {
+  return (
+    typeof v === 'string' &&
+    (COOKING_SKILL_LEVELS as readonly string[]).includes(v)
+  )
+}
+
+export const COOKING_SKILL_LABEL: Record<CookingSkillLevel, string> = {
+  beginner: 'Beginner',
+  intermediate: 'Intermediate',
+  advanced: 'Advanced',
+}
+
+// One-line description shown under each option in the profile UI.
+export const COOKING_SKILL_BLURB: Record<CookingSkillLevel, string> = {
+  beginner: 'Simple recipes and basic techniques',
+  intermediate: 'Comfortable with everyday cooking',
+  advanced: 'Happy to take on involved dishes',
+}
+
+// Per-level guidance appended to the system prompt. Intermediate is the neutral
+// baseline; beginner and advanced pull recipe complexity in either direction.
+export const COOKING_SKILL_PROMPT_GUIDANCE: Record<CookingSkillLevel, string> = {
+  beginner:
+    'The household cooks at a BEGINNER level — favor simple recipes with short ingredient lists and basic techniques. Avoid dishes that assume advanced knife skills, precise timing, or specialty methods.',
+  intermediate:
+    'The household cooks at an INTERMEDIATE level — everyday techniques are fine and the occasional multi-step recipe is welcome, but keep things approachable.',
+  advanced:
+    'The household cooks at an ADVANCED level — involved, technique-heavy recipes are welcome when they fit the request.',
+}
+
+// ── Kitchen equipment ───────────────────────────────────────────────────────
+// The appliances a household can own. `id` is the stable key stored in
+// households.equipment; `label` is the UI + prompt display string. Declaration
+// order is the canonical display/storage order.
+export type EquipmentItem = { id: string; label: string }
+
+export const EQUIPMENT: readonly EquipmentItem[] = [
+  { id: 'oven', label: 'Oven' },
+  { id: 'stovetop', label: 'Stovetop' },
+  { id: 'microwave', label: 'Microwave' },
+  { id: 'slow_cooker', label: 'Slow cooker' },
+  { id: 'instant_pot', label: 'Instant Pot / pressure cooker' },
+  { id: 'air_fryer', label: 'Air fryer' },
+  { id: 'grill', label: 'Grill' },
+  { id: 'blender', label: 'Blender' },
+  { id: 'food_processor', label: 'Food processor' },
+  { id: 'stand_mixer', label: 'Stand mixer' },
+] as const
+
+export const EQUIPMENT_IDS: readonly string[] = EQUIPMENT.map((e) => e.id)
+
+export const EQUIPMENT_LABEL: Record<string, string> = Object.fromEntries(
+  EQUIPMENT.map((e) => [e.id, e.label]),
+)
+
+export function isEquipmentId(v: unknown): v is string {
+  return typeof v === 'string' && EQUIPMENT_IDS.includes(v)
+}
+
+// Normalize an arbitrary payload into a clean, canonically-ordered, deduped
+// list of known equipment ids. Unknown / malformed entries are dropped, so the
+// stored value is always a valid subset of EQUIPMENT_IDS.
+export function normalizeEquipment(input: unknown): string[] {
+  if (!Array.isArray(input)) return []
+  const set = new Set(input.filter(isEquipmentId))
+  return EQUIPMENT.filter((e) => set.has(e.id)).map((e) => e.id)
+}
