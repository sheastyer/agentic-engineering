+// Render the household's cooking profile for the system prompt: skill level (a
+// soft steer on recipe complexity) and owned equipment (a hard constraint on
+// how the meal can be cooked). Returns '' when neither is set so the prompt
+// stays lean for households that haven't filled it in.
+function formatKitchen(
+  skill: CookingSkillLevel | null | undefined,
+  equipment: string[] | null | undefined,
+): string {
+  const lines: string[] = []
+  if (skill) lines.push(COOKING_SKILL_PROMPT_GUIDANCE[skill])
+  const owned = (equipment ?? []).map((id) => EQUIPMENT_LABEL[id] ?? id)
+  if (owned.length > 0) {
+    lines.push(
+      `Available kitchen equipment: ${owned.join(', ')}. Treat this as a hard constraint on how the meal is cooked — only recommend recipes the household can make with the appliances listed here. Never suggest a dish whose core method needs an appliance that isn't listed (e.g. don't propose an air-fryer or slow-cooker recipe unless that appliance appears above).`,
+    )
+  }
+  if (lines.length === 0) return ''
+  return `Kitchen:\n${lines.join('\n')}\n`
+}
