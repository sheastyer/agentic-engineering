+'use client'
+
+import { useRouter } from 'next/navigation'
+import { BackHeader, Screen } from '@/components/ui'
+import { MO_ABBR, parseIso } from '@/lib/dates'
+import {
+  CHANGELOG,
+  groupEntriesByCategory,
+  type ChangelogRelease,
+} from '@/lib/changelog'
+
+// "Jun 30, 2026" style — reuses the same month-abbreviation table as the
+// calendar so date formatting stays consistent app-wide.
+function formatReleaseDate(iso: string): string {
+  const d = parseIso(iso)
+  return `${MO_ABBR[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`
+}
+
+export default function ChangelogPage() {
+  const router = useRouter()
+
+  return (
+    <Screen>
+      <BackHeader title="What's new" onBack={() => router.push('/calendar')} />
+
+      <div
+        style={{
+          flex: 1,
+          overflowY: 'auto',
+          padding: '24px 22px 44px',
+          display: 'flex',
+          flexDirection: 'column',
+        }}
+      >
+        <h1 style={{ fontSize: 18, fontWeight: 700, color: 'var(--text)', letterSpacing: -0.2 }}>
+          What&apos;s new
+        </h1>
+        <p style={{ marginTop: 8, fontSize: 14, lineHeight: 1.6, color: 'var(--text-2)' }}>
+          Recent updates and improvements to your meal planner.
+        </p>
+
+        {CHANGELOG.length === 0 ? (
+          <div
+            style={{
+              marginTop: 28,
+              padding: '28px 18px',
+              borderRadius: 16,
+              border: '1.5px dashed var(--border)',
+              textAlign: 'center',
+              fontSize: 14,
+              color: 'var(--text-2)',
+            }}
+          >
+            No updates yet — check back soon.
+          </div>
+        ) : (
+          CHANGELOG.map((release) => <ReleaseSection key={release.version} release={release} />)
+        )}
+
+        <div style={{ height: 'env(safe-area-inset-bottom)' }} />
+      </div>
+    </Screen>
+  )
+}
+
+function ReleaseSection({ release }: { release: ChangelogRelease }) {
+  const groups = groupEntriesByCategory(release.entries)
+  const headingId = `release-${release.version}`
+
+  return (
+    <section style={{ marginTop: 30 }} aria-labelledby={headingId}>
+      <h2
+        id={headingId}
+        style={{
+          fontSize: 15.5,
+          fontWeight: 700,
+          color: 'var(--text)',
+          display: 'flex',
+          alignItems: 'baseline',
+          gap: 8,
+        }}
+      >
+        Version {release.version}
+        <span style={{ fontSize: 12.5, fontWeight: 500, color: 'var(--text-3)' }}>
+          {formatReleaseDate(release.date)}
+        </span>
+      </h2>
+
+      {groups.length === 0 ? (
+        <p style={{ marginTop: 8, fontSize: 13.5, color: 'var(--text-2)' }}>No details for this release.</p>
+      ) : (
+        groups.map((group) => (
+          <div key={group.category} style={{ marginTop: 14 }}>
+            <h3
+              style={{
+                fontSize: 11.5,
+                fontWeight: 700,
+                letterSpacing: 0.5,
+                textTransform: 'uppercase',
+                color: 'var(--accent)',
+              }}
+            >
+              {group.category}
+            </h3>
+            <ul style={{ margin: '6px 0 0', padding: 0, listStyle: 'none' }}>
+              {group.entries.map((entry, i) => (
+                <li
+                  key={i}
+                  style={{
+                    marginTop: i === 0 ? 0 : 8,
+                    paddingLeft: 16,
+                    position: 'relative',
+                    fontSize: 14,
+                    lineHeight: 1.55,
+                    color: 'var(--text-2)',
+                  }}
+                >
+                  <span
+                    aria-hidden="true"
+                    style={{
+                      position: 'absolute',
+                      left: 0,
+                      top: 9,
+                      width: 5,
+                      height: 5,
+                      borderRadius: '50%',
+                      background: 'var(--accent)',
+                    }}
+                  />
+                  {entry.description}
+                </li>
+              ))}
+            </ul>
+          </div>
+        ))
+      )}
+    </section>
+  )
+}
