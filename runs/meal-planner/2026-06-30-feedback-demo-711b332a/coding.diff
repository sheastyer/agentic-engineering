+// Manually curated release notes for the /changelog page. Update this list
+// whenever a user-facing change ships — entries are written for the
+// household reading them, not for engineers. Newest release first.
+
+export type ChangelogCategory = 'Added' | 'Changed' | 'Fixed'
+
+export type ChangelogEntry = {
+  category: ChangelogCategory
+  description: string
+}
+
+export type ChangelogRelease = {
+  version: string
+  date: string // YYYY-MM-DD
+  entries: ChangelogEntry[]
+}
+
+// Render order for grouping a release's entries by category.
+export const CHANGELOG_CATEGORIES: ChangelogCategory[] = ['Added', 'Changed', 'Fixed']
+
+export const CHANGELOG: ChangelogRelease[] = [
+  {
+    version: '0.4.0',
+    date: '2026-06-30',
+    entries: [
+      {
+        category: 'Added',
+        description: "A changelog page, linked from the calendar footer, so you can see what's new.",
+      },
+    ],
+  },
+  {
+    version: '0.3.0',
+    date: '2026-06-22',
+    entries: [
+      {
+        category: 'Added',
+        description:
+          'A guardrail that keeps the day-by-day planning chat focused on dinner — no more off-topic detours.',
+      },
+    ],
+  },
+  {
+    version: '0.2.0',
+    date: '2026-06-10',
+    entries: [
+      {
+        category: 'Added',
+        description: 'Dark mode, with a toggle in the header that remembers your choice.',
+      },
+      {
+        category: 'Added',
+        description: "A feedback button on every screen so you can tell us what's working (or not).",
+      },
+      {
+        category: 'Changed',
+        description: 'Household preferences now live alongside individual member profiles on one screen.',
+      },
+    ],
+  },
+  {
+    version: '0.1.0',
+    date: '2026-05-26',
+    entries: [
+      {
+        category: 'Added',
+        description: 'The weekly dinner calendar, with a chat panel for each day to get a recommendation.',
+      },
+      {
+        category: 'Added',
+        description: 'Household member profiles — allergies, preferences, and dislikes that shape every suggestion.',
+      },
+      {
+        category: 'Added',
+        description: 'Recipe details pulled in from Spoonacular, with prep time, servings, and ingredients.',
+      },
+    ],
+  },
+]
+
+// Groups a release's entries by category, in CHANGELOG_CATEGORIES order,
+// dropping categories with no entries. Pulled out so the page component
+// stays focused on rendering.
+export function groupEntriesByCategory(
+  entries: ChangelogEntry[],
+): { category: ChangelogCategory; entries: ChangelogEntry[] }[] {
+  return CHANGELOG_CATEGORIES.map((category) => ({
+    category,
+    entries: entries.filter((e) => e.category === category),
+  })).filter((group) => group.entries.length > 0)
+}
