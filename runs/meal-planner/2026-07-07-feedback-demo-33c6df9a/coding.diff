+import { NextResponse } from 'next/server'
+import { and, eq } from 'drizzle-orm'
+import { db } from '@/db/client'
+import { pantryStaples } from '@/db/schema'
+import { requireHousehold, unauthorized } from '@/lib/auth'
+
+export const runtime = 'nodejs'
+
+// DELETE /api/household/pantry-staples/[id] — remove a staple (tenant-scoped).
+export async function DELETE(
+  _req: Request,
+  { params }: { params: Promise<{ id: string }> },
+) {
+  const householdId = await requireHousehold()
+  if (!householdId) return unauthorized()
+  const { id } = await params
+
+  const [row] = await db
+    .delete(pantryStaples)
+    .where(
+      and(eq(pantryStaples.id, id), eq(pantryStaples.householdId, householdId)),
+    )
+    .returning({ id: pantryStaples.id })
+
+  if (!row) {
+    return NextResponse.json({ error: 'staple not found' }, { status: 404 })
+  }
+  return NextResponse.json({ success: true })
+}
