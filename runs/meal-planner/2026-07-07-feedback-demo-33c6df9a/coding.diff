+import { describe, expect, it } from 'vitest'
+import { normalizeStapleInput } from './pantry-staples'
+
+describe('normalizeStapleInput', () => {
+  it('accepts and trims a valid name', () => {
+    expect(normalizeStapleInput({ name: '  Olive Oil  ' })).toEqual({
+      value: { name: 'Olive Oil' },
+    })
+  })
+
+  it('collapses internal control characters to a space', () => {
+    expect(normalizeStapleInput({ name: 'olive\noil' })).toEqual({
+      value: { name: 'olive oil' },
+    })
+  })
+
+  it('rejects a non-object body', () => {
+    expect('error' in normalizeStapleInput(null)).toBe(true)
+    expect('error' in normalizeStapleInput('salt')).toBe(true)
+  })
+
+  it('rejects a missing/non-string name', () => {
+    expect('error' in normalizeStapleInput({})).toBe(true)
+    expect('error' in normalizeStapleInput({ name: 5 })).toBe(true)
+  })
+
+  it('rejects an empty / whitespace-only name', () => {
+    expect(normalizeStapleInput({ name: '' })).toEqual({ error: 'name is required' })
+    expect(normalizeStapleInput({ name: '   ' })).toEqual({ error: 'name is required' })
+    expect(normalizeStapleInput({ name: '\n\t ' })).toEqual({ error: 'name is required' })
+  })
+
+  it('rejects a name over 60 chars (after trim)', () => {
+    expect('error' in normalizeStapleInput({ name: 'a'.repeat(61) })).toBe(true)
+    expect(normalizeStapleInput({ name: 'a'.repeat(60) })).toEqual({
+      value: { name: 'a'.repeat(60) },
+    })
+  })
+})
diff --git a/lib/pantry-staples.ts b/lib/pantry-staples.ts
new file mode 100644
index 0000000..265025c
--- /dev/null
+++ b/lib/pantry-staples.ts
@@ -0,0 +1,34 @@
+// Validation + normalization for pantry-staple create payloads. Pure (no
+// db/network) so it's unit-testable and the route stays thin — same split as
+// lib/members.ts / lib/shopping/validate.ts. A staple is just a short name
+// ("olive oil", "salt", "garlic"); the route derives normalizedName from it.
+import { sanitizeLine } from '@/lib/shopping/validate'
+
+// Staples are short everyday-pantry items — much tighter than the 200-char cap
+// used for shopping-list names. Anything longer is almost certainly a paste
+// accident, not a staple name.
+export const NAME_MAX = 60
+
+export function normalizeStapleInput(
+  body: unknown,
+): { value: { name: string } } | { error: string } {
+  if (typeof body !== 'object' || body === null) {
+    return { error: 'invalid body' }
+  }
+  const b = body as Record<string, unknown>
+
+  if (typeof b.name !== 'string') {
+    return { error: 'name is required' }
+  }
+  // Collapse pasted newlines/tabs to spaces first (same as the shopping-list
+  // name path), then trim.
+  const name = sanitizeLine(b.name).trim()
+  if (!name) {
+    return { error: 'name is required' }
+  }
+  if (name.length > NAME_MAX) {
+    return { error: `name must be at most ${NAME_MAX} characters` }
+  }
+
+  return { value: { name } }
+}
