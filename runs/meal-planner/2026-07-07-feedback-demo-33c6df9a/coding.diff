@@ -0,0 +1,65 @@
+import { NextResponse } from 'next/server'
+import { asc, eq } from 'drizzle-orm'
+import { db } from '@/db/client'
+import { pantryStaples } from '@/db/schema'
+import { requireHousehold, unauthorized } from '@/lib/auth'
+import { normalizeName } from '@/lib/normalize'
+import { normalizeStapleInput } from '@/lib/pantry-staples'
+import type { PantryStapleDto } from '@/lib/types'
+
+export const runtime = 'nodejs'
+
+// Postgres unique_violation SQLSTATE. Both the Neon HTTP driver and
+// node-postgres surface it on `err.code`. Duplicated from lib/shopping/service.ts
+// (not exported there) — consistent with how the codebase already handles this.
+function isUniqueViolation(err: unknown): boolean {
+  return (
+    typeof err === 'object' &&
+    err !== null &&
+    'code' in err &&
+    (err as { code?: unknown }).code === '23505'
+  )
+}
+
+// GET /api/household/pantry-staples — list the household's pantry staples.
+export async function GET() {
+  const householdId = await requireHousehold()
+  if (!householdId) return unauthorized()
+  const rows = await db
+    .select()
+    .from(pantryStaples)
+    .where(eq(pantryStaples.householdId, householdId))
+    .orderBy(asc(pantryStaples.createdAt))
+
+  const staples: PantryStapleDto[] = rows.map((r) => ({ id: r.id, name: r.name }))
+  return NextResponse.json({ staples })
+}
+
+// POST /api/household/pantry-staples — add a staple.
+export async function POST(req: Request) {
+  const householdId = await requireHousehold()
+  if (!householdId) return unauthorized()
+  const parsed = normalizeStapleInput(await req.json().catch(() => null))
+  if ('error' in parsed) {
+    return NextResponse.json({ error: parsed.error }, { status: 400 })
+  }
+
+  const normalizedName = normalizeName(parsed.value.name)
+  try {
+    const [row] = await db
+      .insert(pantryStaples)
+      .values({ householdId, name: parsed.value.name, normalizedName })
+      .returning()
+
+    const staple: PantryStapleDto = { id: row.id, name: row.name }
+    return NextResponse.json({ staple }, { status: 201 })
+  } catch (err) {
+    if (isUniqueViolation(err)) {
+      return NextResponse.json(
+        { error: 'You already have that in your pantry staples' },
+        { status: 409 },
+      )
+    }
+    throw err
+  }
+}
