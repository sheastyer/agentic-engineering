+// Splits items into what still needs buying vs. what's already assumed on
+// hand because it matches a household pantry staple (exact name_norm match —
+// same merge-key convention as the rest of the shopping list). Only staples
+// that actually match a CURRENT item are surfaced this way — the household's
+// full staple list is never shown here, just the overlap.
+type NormedItem = { nameNorm: string }
+
+export function partitionAssumedOnHand<T extends NormedItem>(
+  items: T[],
+  stapleNormNames: ReadonlySet<string>,
+): { buyItems: T[]; assumedOnHand: T[] } {
+  if (stapleNormNames.size === 0) return { buyItems: items, assumedOnHand: [] }
+  const buyItems: T[] = []
+  const assumedOnHand: T[] = []
+  for (const item of items) {
+    if (stapleNormNames.has(item.nameNorm)) assumedOnHand.push(item)
+    else buyItems.push(item)
+  }
+  return { buyItems, assumedOnHand }
+}
