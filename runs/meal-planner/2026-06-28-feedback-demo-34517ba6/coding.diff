@@ -0,0 +1,40 @@
+import { generateText } from 'ai'
+import { model } from '@/lib/ai'
+import { CLASSIFICATION_PROMPT } from './constants'
+
+export type ClassificationResult = 'ON_TOPIC' | 'OFF_TOPIC'
+
+// Classify whether a user message is on-topic for the meal-planning assistant.
+//
+// Design:
+//  - Calls the LLM with a 500 ms hard timeout (AbortSignal.timeout).
+//  - Fail-open: any error or ambiguous response is treated as ON_TOPIC so that
+//    a classifier failure never silently blocks the user.
+//  - The classifier uses maxTokens: 5 to keep the call cheap and fast — we
+//    only need one token ("ON_TOPIC" or "OFF_TOPIC") but allow a small buffer.
+export async function classifyMessage(
+  userMessage: string,
+): Promise<ClassificationResult> {
+  try {
+    const { text } = await generateText({
+      model,
+      system: CLASSIFICATION_PROMPT,
+      messages: [{ role: 'user', content: userMessage }],
+      maxTokens: 5,
+      abortSignal: AbortSignal.timeout(500),
+    })
+
+    // The model should reply with exactly "ON_TOPIC" or "OFF_TOPIC".
+    // Normalise to uppercase and trim to handle any surrounding whitespace.
+    const label = text.trim().toUpperCase()
+    if (label.startsWith('OFF_TOPIC')) {
+      return 'OFF_TOPIC'
+    }
+    // Default fail-open: if the model said something unexpected, let it through.
+    return 'ON_TOPIC'
+  } catch (err) {
+    // Timeout (AbortError), network error, or any other failure → fail open.
+    console.warn('[guardrail] classifier error — failing open:', err)
+    return 'ON_TOPIC'
+  }
+}
