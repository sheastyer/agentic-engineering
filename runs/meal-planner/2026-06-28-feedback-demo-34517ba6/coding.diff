+// ── Guardrail: topic classification constants ─────────────────────────────
+// These constants are shared between the classifier and any code that needs
+// to act on classification results (e.g. the chat route).
+
+// Topics that are in-scope for the meal-planning assistant.
+export const ALLOWED_TOPICS = [
+  'meal planning',
+  'dinner ideas',
+  'recipe recommendations',
+  'cooking techniques',
+  'ingredients',
+  'dietary restrictions',
+  'food allergies',
+  'food preferences',
+  'cuisine types',
+  'weekly meal planning',
+  'nutrition',
+  'grocery items',
+  'meal ratings and feedback',
+] as const
+
+// System prompt given to the classifier LLM. Instructs it to respond with
+// exactly one token: ON_TOPIC or OFF_TOPIC.
+export const CLASSIFICATION_PROMPT = `You are a topic classifier for a household meal-planning assistant.
+
+The assistant is only allowed to help with topics directly related to meal planning, such as:
+${ALLOWED_TOPICS.map((t) => `- ${t}`).join('\n')}
+
+Your job is to classify whether the user's message is relevant to these topics.
+
+Respond with exactly one of these two words — nothing else:
+- ON_TOPIC   (the message is about food, meals, recipes, cooking, or related subjects)
+- OFF_TOPIC  (the message is clearly unrelated to meal planning or food)`
+
+// Friendly reply shown to the user when their message is classified as off-topic.
+// Returned verbatim from the chat API without going through the main LLM.
+export const OFF_TOPIC_RESPONSE =
+  "I'm here to help with meal planning and dinner ideas! I can suggest recipes, work around dietary restrictions, or help you plan your week's dinners. What would you like to eat tonight?"
