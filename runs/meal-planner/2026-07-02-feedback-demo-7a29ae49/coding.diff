+import Link from 'next/link'
+import type { CSSProperties } from 'react'
+import { displayType } from '@/components/logo'
+import { SearchSpot } from '@/components/spot-illustrations'
+import { Screen } from '@/components/ui'
+
+// Next's built-in special file: rendered for any unmatched route (and
+// wherever `notFound()` is called) inside the existing RootLayout, so header
+// nav / footer chrome is preserved — only the body swaps in. Without this
+// file, broken/outdated links fell through to Next's default plain-text 404.
+// A plain long-form screen (no pinned bottom bar), matching household/recipe
+// detail — see CLAUDE.md's mobile ergonomics rule 3.
+export default function NotFound() {
+  return (
+    <Screen>
+      <div style={contentStyle}>
+        <SearchSpot />
+        <div style={titleStyle}>This page wandered off</div>
+        <div style={bodyStyle}>
+          The link you followed doesn&rsquo;t match anything here — it may be outdated or
+          mistyped.
+        </div>
+        <div
+          style={{ display: 'flex', flexDirection: 'column', gap: 10, width: '100%', marginTop: 4 }}
+        >
+          <Link href="/calendar" style={ctaPrimaryStyle}>
+            Back to your week
+          </Link>
+          <Link href="/cookbook" style={ctaSecondaryStyle}>
+            Browse your cookbook
+          </Link>
+        </div>
+      </div>
+    </Screen>
+  )
+}
+
+const contentStyle: CSSProperties = {
+  flex: 1,
+  display: 'flex',
+  flexDirection: 'column',
+  alignItems: 'center',
+  justifyContent: 'center',
+  textAlign: 'center',
+  gap: 12,
+  padding: '48px 22px 44px',
+}
+
+const titleStyle: CSSProperties = {
