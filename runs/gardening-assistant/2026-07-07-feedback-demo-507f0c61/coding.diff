+'use client'
+
+// "Generate plan now" — a manual trigger for POST /api/care-plan/generate
+// (S1), rendered on both Plan and Today headers. Mirrors DoneStep's fetch +
+// phase pattern and TaskCard's router.refresh()-on-success flash, since this
+// is the same "regenerate my plan" action just surfaced outside onboarding.
+
+import { useState } from 'react'
+import { useRouter } from 'next/navigation'
+import { Button } from '@/components/ui'
+
+type Phase = 'idle' | 'loading' | 'error'
+
+export function GeneratePlanButton() {
+  const router = useRouter()
+  const [phase, setPhase] = useState<Phase>('idle')
+  const [error, setError] = useState<string | null>(null)
+  const [flash, setFlash] = useState<string | null>(null)
+
+  async function generate() {
+    setPhase('loading')
+    setError(null)
+    setFlash(null)
+    try {
+      const res = await fetch('/api/care-plan/generate', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({}),
+      })
+      const body = (await res.json().catch(() => null)) as {
+        status?: string
+        error?: { message?: string }
+      } | null
+
+      if (res.ok && (body?.status === 'succeeded' || body?.status === 'running')) {
+        setPhase('idle')
+        router.refresh()
+        setFlash('Plan updated')
+        setTimeout(() => setFlash(null), 2500)
+        return
+      }
+
+      setPhase('error')
+      setError(body?.error?.message ?? "Couldn't generate your plan — try again.")
+    } catch {
+      setPhase('error')
+      setError("Couldn't generate your plan — try again.")
+    }
+  }
+
+  return (
+    <div className="flex flex-col items-start gap-1.5">
+      <Button
+        variant="soft"
+        size="sm"
+        isLoading={phase === 'loading'}
+        onClick={() => void generate()}
+      >
+        {phase === 'loading' ? 'Checking your forecast…' : 'Generate plan now'}
+      </Button>
+      {flash && (
+        <p role="status" className="text-[0.85rem] font-semibold text-leaf">
+          ✓ {flash}
+        </p>
+      )}
+      {error && (
+        <p role="alert" className="text-[0.85rem] text-care-treat-ink">
+          {error}
+        </p>
+      )}
+    </div>
+  )
+}
