@@ -0,0 +1,133 @@
+import { beforeEach, describe, expect, it, vi } from 'vitest'
+
+// ─────────────────────────────────────────────────────────────────────────────
+// POST /care-plan/generate — the Plan/Today "regenerate my plan" trigger. The
+// engine run is delegated to runFirstPlanForGarden (mocked); everything below
+// the handler is mocked, but the care-plan contract stays REAL so the returned
+// payload is validated against carePlanGenerateResponse. Covers: resolving the
+// first garden when no garden_id is given, an explicit owned garden_id, an
+// explicit foreign/absent id → not_found, and an empty group → not_found.
+// ─────────────────────────────────────────────────────────────────────────────
+
+const { requireMemberMock, withTenantMock, listGardensMock, runFirstPlanMock } =
+  vi.hoisted(() => ({
+    requireMemberMock: vi.fn(),
+    withTenantMock: vi.fn(),
+    listGardensMock: vi.fn(),
+    runFirstPlanMock: vi.fn(),
+  }))
+
+vi.mock('@/lib/auth', () => ({ requireMember: requireMemberMock }))
+vi.mock('@/lib/db', () => ({
+  schema: { garden: { id: 'garden.id' } },
+  withTenant: withTenantMock,
+}))
+vi.mock('@/lib/repos/gardens', () => ({ listGardens: listGardensMock }))
+vi.mock('@/lib/jobs/run-first-plan', () => ({
+  runFirstPlanForGarden: runFirstPlanMock,
+}))
+
+import { POST } from './route'
+
+const GROUP_ID = '44444444-4444-4444-4444-444444444444'
+const GARDEN_ID = '11111111-1111-1111-1111-111111111111'
+const RUN_ID = '55555555-5555-5555-5555-555555555555'
+
+/**
+ * The handler passes a tx-using callback to withTenant. We drive it with a fake
+ * tx whose select().from().where().limit() resolves to `ownedRows`.
+ */
+function fakeTx(ownedRows: Array<{ id: string }>) {
+  return {
+    select: () => ({
+      from: () => ({
+        where: () => ({
+          limit: () => Promise.resolve(ownedRows),
+        }),
+      }),
+    }),
+  }
+}
+
+function postReq(body?: Record<string, unknown>): Request {
+  return new Request('http://localhost/api/care-plan/generate', {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: body === undefined ? undefined : JSON.stringify(body),
+  })
+}
+
+beforeEach(() => {
+  vi.clearAllMocks()
+  requireMemberMock.mockResolvedValue({
+    gardenGroupId: GROUP_ID,
+    clerkUserId: 'u1',
+    role: 'owner',
+  })
+  runFirstPlanMock.mockResolvedValue({ engineRunId: RUN_ID, status: 'succeeded' })
+})
+
+describe('POST /api/care-plan/generate', () => {
+  it('resolves the first garden when no garden_id is provided', async () => {
+    withTenantMock.mockImplementation((_group: string, fn: (tx: unknown) => unknown) =>
+      fn(fakeTx([])),
+    )
+    listGardensMock.mockResolvedValue([{ id: GARDEN_ID }, { id: 'other' }])
+
+    const res = await POST(postReq({}))
+
+    expect(res.status).toBe(202)
+    expect(await res.json()).toEqual({
+      engine_run_id: RUN_ID,
+      garden_id: GARDEN_ID,
+      status: 'succeeded',
+    })
+    expect(runFirstPlanMock).toHaveBeenCalledWith({
+      gardenId: GARDEN_ID,
+      gardenGroupId: GROUP_ID,
+    })
+  })
+
+  it('runs for an explicit owned garden_id', async () => {
+    withTenantMock.mockImplementation((_group: string, fn: (tx: unknown) => unknown) =>
+      fn(fakeTx([{ id: GARDEN_ID }])),
+    )
+
+    const res = await POST(postReq({ garden_id: GARDEN_ID }))
+
+    expect(res.status).toBe(202)
+    expect(await res.json()).toEqual({
+      engine_run_id: RUN_ID,
+      garden_id: GARDEN_ID,
+      status: 'succeeded',
+    })
+    expect(listGardensMock).not.toHaveBeenCalled()
+    expect(runFirstPlanMock).toHaveBeenCalledWith({
+      gardenId: GARDEN_ID,
+      gardenGroupId: GROUP_ID,
+    })
+  })
+
+  it('returns not_found for an explicit garden_id not owned by the group', async () => {
+    withTenantMock.mockImplementation((_group: string, fn: (tx: unknown) => unknown) =>
+      fn(fakeTx([])),
+    )
+
+    const res = await POST(postReq({ garden_id: GARDEN_ID }))
+
+    expect(res.status).toBe(404)
+    expect(runFirstPlanMock).not.toHaveBeenCalled()
+  })
+
+  it('returns not_found when the group has no gardens and no id is given', async () => {
+    withTenantMock.mockImplementation((_group: string, fn: (tx: unknown) => unknown) =>
+      fn(fakeTx([])),
+    )
+    listGardensMock.mockResolvedValue([])
+
+    const res = await POST(postReq({}))
+
+    expect(res.status).toBe(404)
+    expect(runFirstPlanMock).not.toHaveBeenCalled()
+  })
+})
