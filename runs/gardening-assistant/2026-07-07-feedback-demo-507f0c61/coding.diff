@@ -0,0 +1,74 @@
+// POST /care-plan/generate — the Plan/Today "regenerate my plan" trigger
+// (care-plan.ts contract).
+//
+// Runs the proactive care engine for ONE garden, authorized by the caller's own
+// Clerk session (NEVER the x-job-secret job endpoint — ARCHITECTURE §11). Like
+// the onboarding run-first-plan route it mirrors, the run is forced and
+// idempotent (reconciliation), so a user mashing the button never produces
+// duplicate tasks.
+//
+// Unlike onboarding, the Today surface has no garden picker: `garden_id` is
+// optional. When provided we verify ownership; when omitted we resolve the
+// group's first garden (gardens[0], the same anchor the Today surface uses).
+//
+// Auth + ownership/resolution are checked under RLS in a short tenant
+// transaction; the engine run itself (which needs the jobs pool for the
+// engine_run ledger + weather cache — off-limits to route code) is delegated to
+// `runFirstPlanForGarden` in lib/jobs and runs AFTER that transaction closes, so
+// withTenant is never nested (composition rule §1).
+import { eq } from 'drizzle-orm'
+import {
+  carePlanGenerateRequest,
+  carePlanGenerateResponse,
+} from '@/lib/contracts/care-plan'
+import { apiError } from '@/lib/contracts/errors'
+import { requireMember } from '@/lib/auth'
+import { schema, withTenant } from '@/lib/db'
+import { parseJsonBody, routeErrorResponse } from '@/lib/http'
+import { listGardens } from '@/lib/repos/gardens'
+import { runFirstPlanForGarden } from '@/lib/jobs/run-first-plan'
+
+export async function POST(req: Request): Promise<Response> {
+  try {
+    const member = await requireMember()
+    const body = await parseJsonBody(req, carePlanGenerateRequest)
+    if (!body.ok) return body.response
+
+    // Resolve the target garden under RLS (short tenant tx). An explicit id is
+    // ownership-checked (RLS scopes the row to the caller's group, so a
+    // foreign/absent garden reads as not-found); an omitted id resolves to the
+    // group's first garden.
+    const gardenId = await withTenant(member.gardenGroupId, async (tx) => {
+      if (body.data.garden_id) {
+        const owned = await tx
+          .select({ id: schema.garden.id })
+          .from(schema.garden)
+          .where(eq(schema.garden.id, body.data.garden_id))
+          .limit(1)
+        return owned[0]?.id ?? null
+      }
+      const gardens = await listGardens(tx)
+      return gardens[0]?.id ?? null
+    })
+
+    if (gardenId === null) {
+      return body.data.garden_id
+        ? apiError('not_found', 'Garden not found.')
+        : apiError('not_found', 'No garden found for this group.')
+    }
+
+    const { engineRunId, status } = await runFirstPlanForGarden({
+      gardenId,
+      gardenGroupId: member.gardenGroupId,
+    })
+
+    const payload = carePlanGenerateResponse.parse({
+      engine_run_id: engineRunId,
+      garden_id: gardenId,
+      status,
+    })
+    return Response.json(payload, { status: 202 })
+  } catch (err) {
+    return routeErrorResponse(err)
+  }
+}
