diff --git a/lib/contracts/care-plan.ts b/lib/contracts/care-plan.ts
new file mode 100644
index 0000000..2b33d19
--- /dev/null
+++ b/lib/contracts/care-plan.ts
@@ -0,0 +1,53 @@
+import { z } from 'zod'
+import { engineRunStatus } from './enums'
+import { registry } from './registry'
+import { withErrors } from './shared'
+
+// ─────────────────────────────────────────────────────────────────────────────
+// Care plan — the user-facing "regenerate my plan" trigger on the Plan/Today
+// surface. Mirrors the onboarding run-first-plan route: it runs the proactive
+// care engine for ONE garden, authorized by the caller's own Clerk session, and
+// is explicitly NOT the raw `x-job-secret` job endpoint (ARCHITECTURE §11). The
+// run is forced and idempotent, so tapping "regenerate" never duplicates tasks.
+//
+// Unlike onboarding (which always carries a specific garden_id from the wizard),
+// the Today UI has no garden picker: `garden_id` is optional and, when omitted,
+// resolves to the group's first garden (gardens[0]).
+// ─────────────────────────────────────────────────────────────────────────────
+
+export const carePlanGenerateRequest = z
+  .object({ garden_id: z.string().uuid().optional() })
+  .openapi('CarePlanGenerateRequest')
+export type CarePlanGenerateRequest = z.infer<typeof carePlanGenerateRequest>
+
+export const carePlanGenerateResponse = z
+  .object({
+    engine_run_id: z.string().uuid(),
+    garden_id: z.string().uuid(),
+    status: engineRunStatus,
+  })
+  .openapi('CarePlanGenerateResponse')
+export type CarePlanGenerateResponse = z.infer<typeof carePlanGenerateResponse>
+
+registry.register('CarePlanGenerateRequest', carePlanGenerateRequest)
+registry.register('CarePlanGenerateResponse', carePlanGenerateResponse)
+
+registry.registerPath({
+  method: 'post',
+  path: '/care-plan/generate',
+  tags: ['care-plan'],
+  summary:
+    'Regenerate the care plan for a garden now, authorized via the caller session (Plan/Today surface)',
+  request: {
+    body: {
+      content: {
+        'application/json': { schema: carePlanGenerateRequest },
+      },
+    },
+  },
+  responses: withErrors({
+    status: 202,
+    description: 'Engine run accepted',
+    schema: carePlanGenerateResponse,
+  }),
+})
