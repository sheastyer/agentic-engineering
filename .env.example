# Copy to .env (gitignored) and fill in as needed. Nothing here is required to run the
# $0 stub flow; these matter once real agents are wired (M3+).

# ── Model provider ───────────────────────────────────────────────────────────
# Which backend the Agent Runner uses. Default: anthropic.
MODEL_PROVIDER=anthropic              # anthropic | vercel

# ── Anthropic (default provider) ─────────────────────────────────────────────
# Leave the key UNSET to use your Claude subscription via `ant auth login` (OAuth
# profile — the dev path that draws on plan credit). Set a direct API key instead for
# pay-as-you-go / production. Never commit a real value.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Vercel AI Gateway (only when MODEL_PROVIDER=vercel) ───────────────────────
# AI_GATEWAY_API_KEY=xxxxxxxx
# VERCEL_OIDC_TOKEN=xxxxxxxx           # alternative to the API key

# ── Temporal ─────────────────────────────────────────────────────────────────
# TEMPORAL_TARGET=localhost:7233       # override the local dev server target

# ── Worker toggles ───────────────────────────────────────────────────────────
# Swap the stubbed triage for the real runner-backed activity (needs provider auth above).
# USE_AGENT_TRIAGE=1

# ── Project secrets (referenced by Project Profiles via secret_refs) ──────────
# meal-planner deploy token — profile secret_ref name: github_token
# MEALPLANNER_GITHUB_TOKEN=xxxxxxxx
