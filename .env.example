# Copy to .env (gitignored) and fill in as needed. Nothing here is required to run the
# $0 stub flow; these matter once the org runs live.

# ── Reasoning plane: Vercel AI Gateway (the only reasoning provider) ──────────
# Required when ORG_LIVE=1. Never commit a real value.
# AI_GATEWAY_API_KEY=xxxxxxxx
# VERCEL_OIDC_TOKEN=xxxxxxxx           # alternative to the API key

# ── Temporal ─────────────────────────────────────────────────────────────────
# TEMPORAL_TARGET=localhost:7233       # override the local dev server target

# ── Worker switches — one per plane ──────────────────────────────────────────
# ORG_LIVE=1                   # every reasoning persona runs live on the gateway
#                              # (off = $0 stubs; needs AI_GATEWAY_API_KEY above)

# ── Coding plane (the engineering pod) — Claude subscription ─────────────────
# USE_AGENT_CODING=1
# CODING_AGENT=mock            # mock (default, $0) | claude (Agent SDK on the Claude SUBSCRIPTION — leave ANTHROPIC_API_KEY UNSET)
# CODING_SANDBOX=local         # local | container (Docker; runs the target's test command for untrusted code)
# CODING_PR_TARGET=local       # local (dry-run branch, no push) | github (push + `gh pr create`; needs gh authed)
# CODING_PERMISSION_MODE=bypassPermissions   # SDK permission mode for non-interactive pod runs
#
# Gotcha: if you launch the worker from INSIDE a Claude Code session, strip its env so the
# pod's spawned `claude` isn't a nested session, else it errors with "error result: success":
#   env -u CLAUDECODE -u CLAUDE_CODE_SSE_PORT -u CLAUDE_CODE_SESSION_ID \
#       -u CLAUDE_CODE_CHILD_SESSION ... ./.venv/bin/python -m worker.main

# ── Project secrets (referenced by Project Profiles via secret_refs) ──────────
# meal-planner deploy token — profile secret_ref name: github_token
# MEALPLANNER_GITHUB_TOKEN=xxxxxxxx

# ── Human I/O: Slack gates + per-run progress thread (M5, D1) ────────────────
# ORG_SLACK=1                  # worker posts gates (buttons) AND stage progress +
#                              # artifacts (PRD/research PDFs) into a per-run thread
# SLACK_BOT_TOKEN=xoxb-...     # bot token, scopes: chat:write, files:write (worker + listener)
# SLACK_APP_TOKEN=xapp-...     # app-level token for Socket Mode (listener only)
# SLACK_CHANNEL_ID=C0XXXXXXX   # one channel for all gates (start simple)
# SLACK_APPROVER_IDS=U0XXXXXXX # comma-separated Slack user ids allowed to move gates
#
# Inbound listener (button click -> Temporal signal; Socket Mode, no public ingress):
#   set -a; . ./.env; set +a; ./.venv/bin/python -m orchestrator.humanio
# The cli.run demo driver stops auto-approving gates when ORG_SLACK is set
# (override with --auto-gates / --no-auto-gates).
